# ==============================================
# POLYMARKET CLOB AUTHENTICATION (L2)
# ==============================================
# API Credentials dari Polymarket (wajib)
POLY_API_KEY=your_api_key_here
POLY_SECRET=your_secret_here
POLY_PASSPHRASE=your_passphrase_here

# Alamat Proxy Wallet (wajib)
FUNDER_ADDRESS=0xYourProxyWalletAddress

# Jenis Signature (1 = Proxy Wallet, 2 = EOA - cek dokumentasi)
SIGNATURE_TYPE=1

# Kunci Privat Wallet untuk Menandatangani Order (wajib, jangan share!)
POLY_PRIVATE_KEY=0xYourPrivateKeyHere

# ==============================================
# BUILDER ATTRIBUTION (untuk atribusi volume)
# ==============================================
# Kode Builder dari profil kamu (bytes32)
POLY_BUILDER_CODE=0xYourBuilderCodeBytes32

# Builder API Credentials (jika pakai Builder API)
POLY_BUILDER_API_KEY=your_builder_api_key
POLY_BUILDER_SECRET=your_builder_secret
POLY_BUILDER_PASSPHRASE=your_builder_passphrase
